{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["DOM", "ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@init-modules/website-builder": [
				"../../website-builder-foundation/website-builder/src/index.ts"
			],
			"@init-modules/website-builder/public": [
				"../../website-builder-foundation/website-builder/src/public.tsx"
			]
		}
	},
	"include": ["src/**/*"]
}
