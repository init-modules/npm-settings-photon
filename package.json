{
	"name": "@init/settings-photon",
	"version": "0.1.0",
	"description": "Locale settings bridge kit for the package-first photon.",
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js",
			"default": "./dist/server.js"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts src/server.ts --format esm --dts --clean",
		"prepack": "npm run build"
	},
	"peerDependencies": {
		"@init/photon": "^0.1.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@init/photon": "file:../../photon-foundation/photon",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"tsup": "^8.5.0",
		"typescript": "^5.9.3"
	},
	"photon": {
		"installableKitExport": "settingsPhotonKit"
	}
}
